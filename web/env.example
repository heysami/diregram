## Public env vars (safe to expose to the browser)
## Copy this file to `.env.local` (create it manually) for local dev.

# Supabase (Auth + future database-backed workspace)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

## Server-only env vars (NEVER expose to the browser)
## These power RAG ingestion + the /api/rag endpoints.

# Supabase service role key (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Internal Docling conversion service (FastAPI) base URL
# Local dev default is: http://127.0.0.1:8686
DOCLING_SERVICE_URL=

# Optional Docling timeout tuning for server-side enqueue/poll flows.
# General default is 240000 ms; PDFs default to 600000 ms because conversion can be much more CPU-heavy.
DOCLING_FETCH_TIMEOUT_MS=
DOCLING_PDF_FETCH_TIMEOUT_MS=

# OpenAI (optional fallback).
# If unset, the app will expect users to supply their own key from the UI (stored locally in-browser)
# and send it to /api/rag/* per request.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Claude (optional fallback for project auto-pipeline generation stages).
# If unset, users provide their Claude key from the UI per run.
# Model selection is auto-discovered from the provided Claude key.
# Set CLAUDE_CHAT_MODEL only to force an override.
CLAUDE_API_KEY=
CLAUDE_CHAT_MODEL=
CLAUDE_TIMEOUT_MS=120000

# Optional: allow server-to-server access without Supabase cookies.
# External callers send: Authorization: Bearer <RAG_API_KEY>
RAG_API_KEY=

# Hosted MCP server base URL for server-side URL generation (preferred).
# Example: https://mcp.yourdomain.com
MCP_SERVER_URL=

# Hosted MCP server base URL (used by Account -> MCP SSH Setup generation).
# Example: https://mcp.yourdomain.com
NEXT_PUBLIC_MCP_SERVER_URL=

# SSH MCP onboarding (used by /account self-setup flow).
# End-user setup scripts write an SSH alias using these values.
NEXT_PUBLIC_MCP_SSH_HOST=
NEXT_PUBLIC_MCP_SSH_PORT=22
NEXT_PUBLIC_MCP_SSH_USER=mcp

# Host sync endpoint auth secret for /api/rag/mcp-ssh/authorized-keys
MCP_SSH_SYNC_SECRET=

# Forced command template for generated authorized_keys lines.
# Must include %TOKEN_HASH% placeholder.
# Example: /usr/bin/env MCP_TOKEN_HASH=%TOKEN_HASH% node /opt/diregram/mcp-server-nexusmap-rag-hosted/src/stdio.js
MCP_SSH_FORCED_COMMAND=

# Optional: ingestion tuning
RAG_EMBED_BATCH_SIZE=96

# Async jobs (Render worker)
# Generate 32-byte key and base64 encode once:
#   openssl rand -base64 32
ASYNC_JOB_ENCRYPTION_KEY=
ASYNC_JOB_POLL_MS=1500
ASYNC_JOB_CONCURRENCY=2
ASYNC_JOB_LEASE_SECONDS=120
ASYNC_JOB_MAX_ATTEMPTS=3

# Collaboration websocket server (Hocuspocus/Yjs)
# Local dev default (if unset) is: ws://localhost:1234
# In production, use wss://...
NEXT_PUBLIC_COLLAB_SERVER_URL=

# Dev-only local admin login shortcut (client-side)
# When enabled, entering "samiadmin" on /login will sign in without magic link.
# Safe default: enabled in development, disabled in production unless explicitly set to "true".
NEXT_PUBLIC_ENABLE_LOCAL_ADMIN_LOGIN=
